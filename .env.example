# .env.example — template, valori vuoti o placeholder. Copia in .env e inserisci i valori reali.
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading
REDIS_URL=redis://localhost:6379/0
ADMIN_API_KEY=change-me-in-production

# LLM (Claude CLI — must be authenticated via `claude auth`)
CLAUDE_CLI_PATH=claude
LLM_DAILY_BUDGET_USD=50.00
LLM_TIMEOUT_SECONDS=120

# Ollama cloud API
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com

# Connectors
NEWSAPI_KEY=
FRED_API_KEY=
DEEPL_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# QuantConnect (cloud backtester — https://www.quantconnect.com/account)
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=

# Alpaca Markets (paper/live trading — https://app.alpaca.markets/paper-trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
